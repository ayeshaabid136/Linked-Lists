struct Node{
    int data;
    Node *next;
};

Node *list = NULL; 

//Search
Node* Search(int value){
   // Node* cur = list;
    if(list == NULL){
        cout<<" Empty is List!\n";
        return NULL;
    }
    Node* cur = list;
    int index = 0;
    while(cur != NULL){
      if(cur->data == value){
        cout<<"Number Found at:" << index <<endl;
        return cur;
       }
    cur= cur->next;
    index++;
    }
   cout<<"Number " << value << " not found in the list!\n";
   return NULL;
}

//Insert
void Insert(int value){
    if(Search(value)){
        cout<< "Duplicate value, Already Exist!\n";
        //return;    
    }
  Node *temp= (Node*)malloc(sizeof(Node));
    temp->data = value;
    temp->next = NULL;

    if(list == NULL){
        list = temp;
    }
    else{
        Node *cur = list;
        while(cur -> next != NULL){
            cur = cur->next;
        }
        cur->next = temp;
    }
}

//Delete Duplicate
void DeleteDuplicate(){
    Node *cur = list;
    while(cur != NULL){   //picks one value
        Node *prev = cur;
        Node *temp = cur->next;    //usky baad wali node check karayga
        while(temp != NULL){
            if(cur->data == temp->data){
                prev->next = temp->next;
                free(temp);
                temp = prev->next;
            }
            else{
                prev = prev->next;
                temp = temp->next;
            }
        }
         cur = cur->next;
    }
}


//Delete
void Delete(int value){   
    //count duplicates while traversing
    int count = 0;
    Node *temp = list;
    while(temp != NULL){
        if(temp->data == value){
            count++;
        }
        temp = temp->next;
    }
    if(count > 0){
        cout<< "Duplicate value,Already Exist!" << count << "times\n";
        return;
    }
    

    if (list == NULL){
        cout << "List Is Empty!\n";
        return;
    }
       else{ 
        if(value == list->data){
            Node* temp = list;  //save pointer to delete
            list= list->next;
            free(temp);
            cout<< "deleted node with value" << value << endl;
            return;
        }

        Node *prev = list;   //For other than 1st element
        Node *cur= list->next;
        while(cur != NULL){
            if(value == cur->data){
                prev->next = cur->next;
                free(cur);
                 cout<< "Deleted node with value" << value << endl;
                return;
            }
            cur = cur->next;
            prev = prev->next;
        }
    }
    cout<< value << "Not found in the list \n";
}

//BubbleSort
void BubbleSort(Node* list){
    if(list == NULL){
        cout<< "List is empty\n";
        return;
    }
        bool swapped;
        do{
            swapped = false;
            Node *cur = list;
            while(cur->next != NULL){
                if(cur->data > cur->next->data){
                    int temp = cur->data;
                    cur->data = cur->next->data;
                    cur->next->data = temp;
                    swapped = true;
                }
                cur= cur->next;
            }
        }
        while(swapped);
}

//Selection sort
void SelectionSort(Node* list){
    if(list == NULL){
        cout<<"List Is Empty\n";
        return;
    }
    for(Node* i=list; i; i=i->next){
        Node* min = i;
        for(Node* j=i->next; j; j=j->next){
            if(j->data > min->data){
                min = j;
            }
            int temp = j->data;
            j->data = min->data;
            min->data = temp;
        }
    }
}
void InsertionSort(Node* list){
    if(list == NULL){
        cout<< "List Is empty\n";
        return;
    }
    for(Node* i=list->next; i != NULL; i=i->next){
        int hold = i->data;
        Node* gap = list;
        while(gap != i){
            if(gap->data > hold){
                int  temp = gap->data;
                gap->data = hold;
                hold = temp;
            }
            gap = gap->next;
        }
        i->data = hold;
    }
}

//Display
void Display(){
    if(list == NULL){
        cout << "List Is Empty!\n";
        return;
    }
    Node *cur = list;
    while(cur != NULL){
        cout<< cur->data;
        cout<< "->";
        cur = cur->next;
    }
     cout<<endl;
}

//Forward Display
void forwardDisplay(Node* list){
    if(list == NULL){
        return;
    }
    cout<< list->data;
    if(list->next != NULL){
        cout<< "->";
    }
    forwardDisplay(list->next);
}

//BackwardDisplay
void BackwardDisplay(Node* list){
    if(list == NULL){
      return;
    } 
    BackwardDisplay(list->next);
    cout<< list->data;
    if(list->next != NULL){
        cout<< "<-";
    }else{
        cout <<endl;
    }
}



